# ============================================================
# SERENITY AI - Environment Variables
# Copy this to .env.local (admin dashboard) or .env (functions)
# NEVER commit .env files to git
# ============================================================

# ============================================================
# SUPABASE
# ============================================================
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_DB_PASSWORD=YOUR_DB_PASSWORD

# ============================================================
# GROQ API (AI Engine for general non-booking questions)
# ============================================================
AI_PROVIDER=groq
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=240
GROQ_TEMPERATURE=0.7
GROQ_TIMEOUT_MS=8500
GROQ_DAILY_BUDGET_USD=10

# ============================================================
# DEEPGRAM (Speech-to-Text + optional TTS)
# ============================================================
DEEPGRAM_API_KEY=YOUR_DEEPGRAM_API_KEY
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=en
# Enable PII/PHI redaction - ALWAYS TRUE for production
DEEPGRAM_REDACT_PII=true
DEEPGRAM_DAILY_BUDGET_USD=5

# ============================================================
# WHATSAPP PROVIDER
# Default is Twilio because the deployed MVP is Twilio-first.
# Use "meta" only after Meta Cloud API webhook + sender testing passes.
# ============================================================
WHATSAPP_PROVIDER=twilio

# ============================================================
# TWILIO WHATSAPP + SMS
# https://console.twilio.com/
# ============================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
# sandbox until Twilio approves the live WhatsApp sender; switch to live only after the live sender test passes.
TWILIO_WHATSAPP_MODE=sandbox
TWILIO_WHATSAPP_NUMBER=+14155238886
# Set after Twilio WhatsApp Self Sign-up approves the hospital sender.
TWILIO_LIVE_WHATSAPP_NUMBER=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
TWILIO_WEBHOOK_URL=https://YOUR_PROJECT_ID.supabase.co/functions/v1/whatsapp-webhook
STAFF_BOOKING_WHATSAPP_TO=+2348062197384
PRIMARY_DOCTOR_NAME=Dr. Adekunle Adesina
PRIMARY_DOCTOR_WHATSAPP=+2348062197384
OPERATIONS_MANAGER_NAME=Abdullahi Rahinatu
OPERATIONS_MANAGER_WHATSAPP=+2348072023652
# Optional comma-separated extra WhatsApp numbers allowed to request admin summaries/reminders
ADMIN_COMMAND_WHATSAPP_NUMBERS=
BOOKING_NOTIFY_WHATSAPP_ENABLED=true
BOOKING_NOTIFY_EMAIL_ENABLED=true

# ============================================================
# META WHATSAPP CLOUD API (optional direct fallback)
# https://developers.facebook.com/docs/whatsapp/cloud-api/
# ============================================================
META_GRAPH_API_VERSION=v21.0
META_APP_ID=
META_APP_SECRET=
META_BUSINESS_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_DISPLAY_PHONE_NUMBER=
WHATSAPP_PERMANENT_ACCESS_TOKEN=
META_WEBHOOK_VERIFY_TOKEN=GENERATE_STRONG_RANDOM_VERIFY_TOKEN
META_WEBHOOK_URL=https://YOUR_PROJECT_ID.supabase.co/functions/v1/meta-whatsapp-webhook

# ============================================================
# GOOGLE CALENDAR API
# Create service account: https://console.cloud.google.com/
# ============================================================
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","client_email":"serenity-calendar@YOUR_PROJECT.iam.gserviceaccount.com","private_key":"-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"}
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com

# ============================================================
# EMAIL (HTTP API provider for Edge Functions)
# Use one provider. Brevo is recommended if SMTP2GO signup is unavailable.
# ============================================================
BREVO_API_KEY=YOUR_BREVO_API_KEY
RESEND_API_KEY=YOUR_RESEND_API_KEY
SMTP_API_KEY=YOUR_SMTP2GO_API_KEY
SMTP_USER=notifications@serenityroyalehospital.com
EMAIL_FROM_NAME="Serenity Royale Hospital"
EMAIL_FROM_ADDRESS=notifications@serenityroyalehospital.com
STAFF_BOOKING_EMAIL_TO=info@serenityroyalehospital.com

# ============================================================
# HOSPITAL INFORMATION (from serenityroyalehospital.com)
# ============================================================
HOSPITAL_NAME="Serenity Royale Hospital"
HOSPITAL_WEBSITE=https://serenityroyalehospital.com
HOSPITAL_EMAIL=info@serenityroyalehospital.com
HOSPITAL_PHONE_PRIMARY=+2348062197384
HOSPITAL_PHONE_SECONDARY=+2348116891990
HOSPITAL_WHATSAPP_PRIMARY=+2348062197384
HOSPITAL_WHATSAPP_SECONDARY=+2348116891990
HOSPITAL_SOCIAL_MEDIA=@serenityroyale_
HOSPITAL_HEAD_OFFICE="No. 10 Royal Homes Estate, Galadimawa, Abuja"
HOSPITAL_ANNEX="No. 11 Ali Amodu Close (behind CBN Quarters), Karu, Abuja"
# MD contact (for emergency escalations)
HOSPITAL_MD_PHONE=+2348062197384
HOSPITAL_MD_WHATSAPP=+2348062197384
HOSPITAL_MD_EMAIL=info@serenityroyalehospital.com
# Emergency escalation switchboard (secondary after MD)
HOSPITAL_SWITCHBOARD=+2348116891990

# ============================================================
# APPLICATION SETTINGS
# ============================================================
TIMEZONE=Africa/Lagos
NODE_ENV=production
# Max appointment booking window (months)
MAX_BOOKING_MONTHS=6
# Booking session timeout (minutes)
BOOKING_SESSION_TIMEOUT_MINUTES=30
# Emergency alert deduplication window (minutes)
EMERGENCY_DEDUP_WINDOW_MINUTES=10
# Groq rate limit buffer
GROQ_RATE_LIMIT_RPM=35

# ============================================================
# SECURITY
# ============================================================
# Random 32+ char string - generate with: openssl rand -base64 32
JWT_SECRET=GENERATE_STRONG_RANDOM_SECRET_HERE
ENCRYPTION_KEY=GENERATE_STRONG_32_CHAR_KEY_HERE
WEBHOOK_SIGNATURE_SECRET=GENERATE_STRONG_RANDOM_SECRET_HERE
# Used by Edge Functions to call each other without exposing service-role details in request bodies
INTERNAL_FUNCTION_SECRET=GENERATE_STRONG_RANDOM_32_PLUS_CHAR_SECRET_HERE

# ============================================================
# NEXT.JS PUBLIC VARS (admin dashboard)
# These are safe to expose to browser
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NEXT_PUBLIC_APP_URL=https://admin.serenityroyalehospital.com
NEXT_PUBLIC_HOSPITAL_NAME="Serenity Royale Hospital"
NEXT_PUBLIC_HOSPITAL_PHONE=+2348062197384

# ============================================================
# MONITORING (optional but recommended)
# ============================================================
# Sentry for error tracking
SENTRY_DSN=https://YOUR_KEY@sentry.io/YOUR_PROJECT_ID
